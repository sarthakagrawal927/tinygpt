---
// Auto-generated by scripts/convert_to_astro.mjs from roadmap.html.
// Edit the HTML source then re-run the script, or edit this .astro file
// directly — both are valid. Keep IDs/attributes stable for src/main.ts and
// the popover system to keep wiring up correctly.
import Default from "../layouts/Default.astro";

const layoutProps = {
  title: "TinyGPT — the performance journey",
  description: "The performance journey of TinyGPT — every speed lever, what's shipped, what's blocked, and why.",
  ogType: "article",
  ogTitle: "TinyGPT — the performance journey",
  ogDescription: "Every speed lever, what's shipped, what's blocked, and why. Scalar → SIMD → threads → WebGPU naive → blocked-4×4. The 9.7× end-to-end speedup, anchored to numbers you can reproduce.",
  twitterTitle: "TinyGPT — the performance journey",
  twitterDescription: "Every speed lever in TinyGPT, what's shipped, what's blocked, and why — with reproducible numbers.",
  themeColor: "#08090a",
};

const pageStyle = `
      :root {
        color-scheme: dark;
        --base: #08090a;
        --panel: #0d0e10;
        --panel-2: #141518;
        --line: #1d1f23;
        --line-strong: #2c2f35;
        --fg: #e7e8ea;
        --muted: #9296a0;
        --faint: #787d88;
        --accent: #48e5c2;
        --accent-dim: #1f6f5f;
        --accent-glow: #48e5c233;
        --warn: #f5b14a;
        --danger: #ff6868;
        --font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, sans-serif;
        --font-mono: "Geist Mono", ui-monospace, "SF Mono", "JetBrains Mono", monospace;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }
      * { box-sizing: border-box; }
      html, body { background: var(--base); }
      body {
        margin: 0;
        font: 15px/1.6 var(--font-sans);
        color: var(--fg);
        -webkit-font-smoothing: antialiased;
      }
      body::before {
        content: "";
        position: fixed; inset: 0;
        background:
          radial-gradient(ellipse 800px 400px at 30% -10%, rgba(72, 229, 194, 0.06), transparent 70%),
          radial-gradient(ellipse 600px 400px at 90% 10%, rgba(72, 229, 194, 0.04), transparent 70%);
        pointer-events: none; z-index: -1;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      code, pre { font-family: var(--font-mono); }

      .wrap { max-width: 820px; margin: 0 auto; padding: 64px 28px 160px; }

      /* Header */
      header { margin-bottom: 56px; }
      .nav-back {
        display: inline-flex; align-items: center; gap: 6px;
        font: 500 12px/1 var(--font-mono);
        color: var(--muted);
        padding: 7px 12px;
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        text-decoration: none;
        transition: all 0.18s ease;
        margin-bottom: 28px;
      }
      .nav-back:hover {
        color: var(--accent);
        border-color: var(--accent-dim);
        background: var(--accent-glow);
        text-decoration: none;
        transform: translateX(-2px);
      }
      .brand {
        display: flex; align-items: center; gap: 14px;
        margin: 0 0 18px;
      }
      .brand-mark svg {
        filter: drop-shadow(0 0 8px rgba(72, 229, 194, 0.18));
      }
      .brand h1 {
        font-size: 32px; font-weight: 600; letter-spacing: -0.015em;
        margin: 0;
        background: linear-gradient(135deg, var(--fg) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .brand .tag {
        font: 500 10.5px/1 var(--font-mono);
        color: var(--accent);
        border: 1px solid var(--accent-dim);
        background: var(--accent-glow);
        padding: 5px 9px; border-radius: 999px;
        letter-spacing: 0.06em; text-transform: uppercase;
      }
      .lede {
        color: var(--muted);
        font-size: 15.5px; line-height: 1.7;
        max-width: 680px;
      }
      .lede strong { color: var(--fg); font-weight: 500; }
      .lede em { color: var(--accent); font-style: normal; }

      /* Status legend */
      .legend {
        display: flex; gap: 12px; flex-wrap: wrap;
        margin: 36px 0 56px;
        padding: 18px 22px;
        background: var(--panel-2);
        border: 1px solid var(--line);
        border-radius: 10px;
      }
      .legend-item {
        display: inline-flex; align-items: center; gap: 8px;
        font: 500 12px/1 var(--font-mono);
        color: var(--muted);
      }
      .legend-item .dot {
        width: 8px; height: 8px; border-radius: 50%;
        display: inline-block;
      }

      /* Lever cards */
      .lever {
        margin-bottom: 32px;
        padding: 28px 32px;
        background: linear-gradient(180deg, var(--panel) 0%, color-mix(in srgb, var(--panel) 96%, var(--base)) 100%);
        border: 1px solid var(--line);
        border-radius: 14px;
        transition: border-color 0.18s ease, transform 0.18s ease;
        animation: rise-in 0.5s var(--ease-out-expo) both;
      }
      .lever:hover {
        border-color: var(--line-strong);
        transform: translateY(-2px);
      }
      .lever:nth-of-type(2) { animation-delay: 0.03s; }
      .lever:nth-of-type(3) { animation-delay: 0.06s; }
      .lever:nth-of-type(4) { animation-delay: 0.09s; }
      .lever:nth-of-type(5) { animation-delay: 0.12s; }
      .lever:nth-of-type(6) { animation-delay: 0.15s; }
      .lever:nth-of-type(7) { animation-delay: 0.18s; }
      .lever:nth-of-type(8) { animation-delay: 0.21s; }
      .lever:nth-of-type(9) { animation-delay: 0.24s; }
      @keyframes rise-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @media (prefers-reduced-motion: reduce) {
        .lever { animation: none; }
      }

      .lever-head {
        display: flex; align-items: flex-start; gap: 14px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .lever-num {
        font: 600 11px/1 var(--font-mono);
        color: var(--accent);
        background: var(--accent-glow);
        border: 1px solid var(--accent-dim);
        border-radius: 50%;
        width: 28px; height: 28px;
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
      }
      .lever-title {
        flex: 1; min-width: 0;
        font: 500 17px/1.3 var(--font-sans);
        color: var(--fg);
        letter-spacing: -0.005em;
        margin: 4px 0 0;
      }

      .status {
        display: inline-flex; align-items: center; gap: 6px;
        font: 500 11px/1 var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 5px 10px;
        border-radius: 999px;
        white-space: nowrap;
      }
      .status .dot {
        width: 6px; height: 6px; border-radius: 50%;
        display: inline-block;
      }
      .status.shipped { color: var(--accent); background: var(--accent-glow); border: 1px solid var(--accent-dim); }
      .status.shipped .dot { background: var(--accent); }
      .status.partial { color: var(--warn); background: #f5b14a1f; border: 1px solid #5b4423; }
      .status.partial .dot { background: var(--warn); animation: pulse 1.6s ease-in-out infinite; }
      .status.blocked { color: var(--danger); background: #ff68681c; border: 1px solid #5b2a2a; }
      .status.blocked .dot { background: var(--danger); }
      .status.open { color: var(--muted); background: var(--panel-2); border: 1px solid var(--line-strong); }
      .status.open .dot { background: var(--muted); }
      .status.in-progress { color: var(--warn); background: #f5b14a1f; border: 1px solid #5b4423; }
      .status.in-progress .dot { background: var(--warn); animation: pulse 1.6s ease-in-out infinite; }
      .status.planned { color: var(--muted); background: var(--panel-2); border: 1px solid var(--line); }
      .status.planned .dot { background: var(--muted); }
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.4); }
      }

      .lever-meta {
        display: flex; gap: 16px; flex-wrap: wrap;
        margin: 4px 0 18px 42px;
        font: 500 12px/1 var(--font-mono);
        color: var(--faint);
      }
      .lever-meta strong { color: var(--accent); font-weight: 500; }

      .lever-body { color: var(--muted); font-size: 14.5px; line-height: 1.65; }
      .lever-body p { margin: 0 0 12px; }
      .lever-body p:last-child { margin-bottom: 0; }
      .lever-body strong { color: var(--fg); font-weight: 500; }
      .lever-body code {
        background: var(--panel-2);
        border: 1px solid var(--line);
        color: var(--accent);
        padding: 1px 5px;
        border-radius: 3px;
        font-size: 12.5px;
      }
      .lever-body a { color: var(--accent); text-decoration: underline; text-decoration-color: var(--accent-dim); }
      .lever-body .why { display: flex; gap: 10px; margin-top: 14px; }
      .lever-body .why-key {
        font: 500 11px/1.5 var(--font-mono);
        color: var(--faint);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        min-width: 80px;
        padding-top: 1px;
      }
      .lever-body .why-val { flex: 1; }
      .lever-body ul { margin: 8px 0 0 18px; padding: 0; }
      .lever-body li { margin: 4px 0; }

      /* Benchmark log + tables */
      .bench-log {
        background: linear-gradient(180deg, var(--panel) 0%, color-mix(in srgb, var(--panel) 92%, var(--accent-glow)) 100%);
        border-color: var(--accent-dim);
      }
      .bench-log .lever-num {
        background: var(--accent-glow);
        color: var(--accent);
        border-color: var(--accent-dim);
      }
      .bench-table {
        width: 100%;
        margin: 14px 0;
        border-collapse: collapse;
        font: 500 12.5px/1.4 var(--font-mono);
      }
      .bench-table thead th {
        text-align: left;
        font: 500 10.5px/1 var(--font-mono);
        color: var(--faint);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 8px 12px;
        border-bottom: 1px solid var(--line-strong);
      }
      .bench-table tbody td {
        padding: 8px 12px;
        border-bottom: 1px solid var(--line);
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }
      .bench-table tbody tr:last-child td { border-bottom: none; }
      .bench-table tbody td:first-child { color: var(--fg); font-weight: 500; }

      /* Speed-evolution chart */
      .evo-chart {
        margin-top: 6px;
        display: grid;
        gap: 8px;
      }
      .evo-row {
        display: grid;
        grid-template-columns: 200px 1fr 64px 78px;
        align-items: center;
        gap: 12px;
        font: 500 12.5px/1 var(--font-mono);
      }
      .evo-label {
        color: var(--muted);
        text-align: right;
        white-space: nowrap;
      }
      .evo-bar {
        height: 14px;
        width: var(--w);
        border-radius: 3px;
        transition: filter 0.18s ease;
      }
      .evo-bar.shipped {
        background: linear-gradient(90deg, var(--accent-dim), var(--accent));
        box-shadow: 0 0 12px var(--accent-glow);
      }
      .evo-bar.planned {
        background: repeating-linear-gradient(
          135deg,
          #3a3f4a 0px,
          #3a3f4a 6px,
          #4a4f5a 6px,
          #4a4f5a 12px
        );
        opacity: 0.78;
      }
      .evo-bar:hover { filter: brightness(1.15); }
      .evo-val {
        color: var(--fg);
        font-weight: 500;
        text-align: right;
      }
      .evo-tag {
        font: 500 10.5px/1 var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--faint);
        text-align: left;
      }
      .evo-row:has(.evo-bar.shipped) .evo-tag {
        color: var(--accent);
      }
      @media (max-width: 720px) {
        .evo-row {
          grid-template-columns: 1fr;
          gap: 4px;
          padding: 8px 0;
          border-bottom: 1px dashed var(--line);
        }
        .evo-row:last-child { border-bottom: none; }
        .evo-label { text-align: left; }
        .evo-bar { width: var(--w); }
        .evo-val { text-align: left; }
      }

      footer {
        margin-top: 80px;
        padding-top: 32px;
        border-top: 1px solid var(--line);
        color: var(--faint);
        font-size: 13px;
        display: flex; gap: 14px; flex-wrap: wrap;
      }
      footer a { color: var(--muted); }
      footer a:hover { color: var(--accent); }
    `;

const pageBody = `
    <div class="wrap">
      <header>
        <a href="/" class="nav-back">← Back to the playground</a>
        <div class="brand">
          <div class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="40" height="40">
              <rect width="32" height="32" rx="8" fill="#0d0e10"/>
              <rect x="0.5" y="0.5" width="31" height="31" rx="7.5" fill="none" stroke="#48e5c2" stroke-opacity="0.35"/>
              <path d="M 5 7 C 9 7 11 21 17 24 C 21 26 23 26 27 26"
                    fill="none" stroke="#48e5c2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="27" cy="26" r="2.6" fill="#48e5c2"/>
              <circle cx="27" cy="26" r="5.5" fill="#48e5c2" fill-opacity="0.18"/>
            </svg>
          </div>
          <h1>The performance journey</h1>
          <span class="tag">roadmap</span>
        </div>
        <p class="lede">
          A live ledger of every lever that would make in-browser training of TinyGPT
          faster — what's shipped, what's blocked, what's open, and the honest reason
          each is in the state it's in. <strong>~80% of training time is matmul</strong>;
          most of these levers attack it from a different angle.
        </p>
      </header>

      <div class="legend">
        <span class="legend-item"><span class="dot" style="background:#48e5c2"></span> Shipped — running today</span>
        <span class="legend-item"><span class="dot" style="background:#f5b14a"></span> Partial — exists but unverified</span>
        <span class="legend-item"><span class="dot" style="background:#ff6868"></span> Blocked — external constraint</span>
        <span class="legend-item"><span class="dot" style="background:#9296a0"></span> Open — not started</span>
      </div>

      <!-- Benchmark log -->
      <article class="lever bench-log">
        <div class="lever-head">
          <span class="lever-num">●</span>
          <h2 class="lever-title">Benchmark log</h2>
          <span class="status shipped"><span class="dot"></span> Measured</span>
        </div>
        <div class="lever-meta">
          <span>Machine: <strong>Apple M-series</strong></span>
          <span>Build: <code>emcc -O3 -msimd128</code></span>
          <span>Driver: <code>tests/bench_wasm.mjs</code></span>
        </div>
        <div class="lever-body">
          <p>
            Every reported number on this page is run-on-this-machine, not extrapolation.
            The numbers below are <code>ms / training step</code> at batch 16/12/8 on the
            single-threaded WASM-SIMD build — the current shipped baseline.
          </p>
          <p style="margin-top: 16px"><strong>Current shipped build — multi-threaded WASM SIMD:</strong></p>
          <table class="bench-table">
            <thead>
              <tr><th>Preset</th><th>Params</th><th>d_model</th><th>ctx</th><th>ms/step</th><th>tok/s</th></tr>
            </thead>
            <tbody>
              <tr><td>Small</td><td>0.37M</td><td>96</td><td>64</td><td>101</td><td>10,116</td></tr>
              <tr><td>Medium</td><td>0.84M</td><td>128</td><td>96</td><td>357</td><td>4,305</td></tr>
              <tr><td>Large</td><td>2.74M</td><td>192</td><td>128</td><td>1,191</td><td>1,289</td></tr>
              <tr><td>XL</td><td>6.42M</td><td>256</td><td>128</td><td>1,851</td><td>553</td></tr>
            </tbody>
          </table>
          <p style="margin-top: 14px; color: var(--faint); font-size: 12.5px;">
            (Previously, single-threaded SIMD: ~2× slower across the board. See lever 3.)
          </p>
          <p>
            For WebGPU on the same hardware, the first user-measured datapoint is
            <strong>~7× faster than WASM SIMD</strong>: a run estimated at 7 minutes
            on WASM finished in ~1 minute on WebGPU. WebGPU benchmarks across
            multiple machines are still TBD — see lever 2.
          </p>
          <div class="why">
            <span class="why-key">How to reproduce</span>
            <span class="why-val">
              <code>bash wasm/build_wasm.sh &amp;&amp; node tests/bench_wasm.mjs</code>
              from the repo root. Reports ms/step per preset, both forward and backward.
            </span>
          </div>
        </div>
      </article>

      <!-- Speed-evolution chart -->
      <article class="lever speed-evo">
        <div class="lever-head">
          <span class="lever-num">●</span>
          <h2 class="lever-title">Speed evolution — Small preset, normalized to scalar baseline</h2>
          <span class="status shipped"><span class="dot"></span> Measured + extrapolated</span>
        </div>
        <div class="lever-meta">
          <span>Baseline: <strong>1×</strong> = single-threaded scalar WASM</span>
          <span>Reading: each bar is the cumulative speedup over baseline</span>
        </div>
        <div class="lever-body">
          <div class="evo-chart" role="img" aria-label="Bar chart showing relative training speed across project phases">
            <!-- Solid bars = measured. Striped bars = projected from per-lever impact estimates. -->
            <div class="evo-row">
              <span class="evo-label">scalar baseline</span>
              <span class="evo-bar shipped" style="--w: 1.5%"></span>
              <span class="evo-val">1.0×</span>
              <span class="evo-tag">measured</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ WASM SIMD</span>
              <span class="evo-bar shipped" style="--w: 2.5%"></span>
              <span class="evo-val">1.6×</span>
              <span class="evo-tag">measured</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ multi-thread (4 workers)</span>
              <span class="evo-bar shipped" style="--w: 5%"></span>
              <span class="evo-val">3.2×</span>
              <span class="evo-tag">measured</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ WebGPU naive</span>
              <span class="evo-bar shipped" style="--w: 11%"></span>
              <span class="evo-val">~7×</span>
              <span class="evo-tag">end-to-end measured (Small preset)</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ WebGPU blocked matmul</span>
              <span class="evo-bar shipped" style="--w: 19%"></span>
              <span class="evo-val">~12×</span>
              <span class="evo-tag">end-to-end measured · 7.6× over WASM SIMD on Small preset · 0.5% loss drift</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ blocked on big-matmul presets (Mega+)</span>
              <span class="evo-bar shipped" style="--w: 48%"></span>
              <span class="evo-val">~30×</span>
              <span class="evo-tag">kernel measured · 5.2× kernel speedup at 2048³</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ WebGPU subgroups (softmax, layernorm)</span>
              <span class="evo-bar planned" style="--w: 60%"></span>
              <span class="evo-val">~36×</span>
              <span class="evo-tag">projected</span>
            </div>
            <div class="evo-row">
              <span class="evo-label">+ Flash Attention 2 (ctx 512)</span>
              <span class="evo-bar planned" style="--w: 100%"></span>
              <span class="evo-val">~60–80×</span>
              <span class="evo-tag">projected</span>
            </div>
          </div>
          <p style="margin-top: 18px; color: var(--muted); font-size: 13.5px;">
            <strong>Solid teal bars</strong> are measured end-to-end on this codebase:
            <code>tests/test_webgpu_train.mjs</code> compares WASM vs WebGPU final loss
            after 50 steps on the same seed — the WebGPU + blocked-matmul run finishes
            in 0.9 s vs 6.8 s for WASM, with 0.5% loss drift (pure float-reorder noise,
            model trains identically). Bigger presets see more benefit because the
            blocked kernel's win grows with matmul size — at 2048³ the standalone
            kernel is 5.18× faster than naive, vs ~1.5–2× on Small-preset shapes.
            <strong>Striped bars</strong> are projected from per-lever impact estimates.
          </p>
          <div style="margin-top: 14px; padding: 10px 14px; border-left: 2px solid var(--accent); background: var(--accent-glow); border-radius: 0 6px 6px 0;">
            <p style="margin: 0; color: var(--muted); font-size: 13px;">
              <strong style="color: var(--accent); font: 500 11px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 4px;">orthogonal lever</strong>
              <strong>Memory64</strong> doesn't appear as a bar because it lifts the
              <em>model-size ceiling</em>, not training throughput. At fixed Small-preset
              size it's a no-op — but it's the only thing that lets the whole optimised
              pipeline run on a 473M-param model in the first place (a config that
              hard-OOMs the 32-bit WASM build).
            </p>
          </div>
        </div>
      </article>

      <!-- 1: SIMD — shipped -->
      <article class="lever">
        <div class="lever-head">
          <span class="lever-num">1</span>
          <h2 class="lever-title">WebAssembly SIMD in the matmul inner loop</h2>
          <span class="status shipped"><span class="dot"></span> Shipped</span>
        </div>
        <div class="lever-meta">
          <span>Impact: <strong>~1.6×</strong> per project notes</span>
          <span>Lives in: <code>wasm/src/matmul.cpp</code></span>
        </div>
        <div class="lever-body">
          <p>
            The C++ matmul is compiled twice — once scalar, once with <code>-msimd128</code>.
            With SIMD on, four f32 lanes multiply per cycle in the inner loop instead of one.
            <code>docs/performance.md</code> reports ~1.6×; current build is SIMD by default
            (the numbers in the Benchmark log above are SIMD-on).
          </p>
          <p>
            The page's "WASM SIMD" pill at top shows whether your browser actually loaded
            the SIMD build. All Chromium-family browsers and Safari 16.4+ do.
          </p>
          <div class="why">
            <span class="why-key">Why now</span>
            <span class="why-val">Smallest cost / biggest immediate win.
            Doesn't change any maths, just generates better machine code.
            See <a href="https://github.com/sarthakagrawal927/tinygpt/blob/main/docs/performance.md">docs/performance.md</a>.</span>
          </div>
        </div>
