---
/**
 * /docs/ — landing page listing every rendered doc.
 * Each card links into the matching wrapper page (also under /docs/).
 */
import Default from "../../layouts/Default.astro";

const layoutProps = {
  title: "TinyGPT — documentation library",
  description: "The full docs library — lessons learned, a session retrospective, a chronological Q&A log, a decision log, a thematic study guide, and an annotated transcript. Pick the angle that fits.",
  ogType: "article" as const,
  ogTitle: "TinyGPT — documentation library",
  ogDescription: "Every angle on a long building session: lessons, retrospective, Q&A, decisions, study guide, annotated transcript.",
  themeColor: "#0a0c10",
};

const docs = [
  {
    href: "/docs/lessons",
    title: "Lessons from this build",
    blurb: "The transferable lessons distilled — the LR-default bug, the Memory64 race, the speedup-curve framing, why standalone benchmarks lie, algorithm-in-JS-first.",
    tag: "lessons",
  },
  {
    href: "/docs/session_retrospective",
    title: "Session retrospective",
    blurb: "Seven arcs in 3,000 words: belief → contradiction → fix → lesson. Third-person, dense, written to be read once and remembered.",
    tag: "retrospective",
  },
  {
    href: "/docs/qa_log",
    title: "Q&A log",
    blurb: "Every major question Sarthak asked, answered in 2–4 sentences with a pointer to what shipped. Skim to remember what was asked, find the answer fast.",
    tag: "Q&A",
  },
  {
    href: "/docs/decision_log",
    title: "Decision log",
    blurb: "Eighteen turning points where direction changed. Each entry: context → trigger → call → why-it-was-right → what-shipped. The meta-log of the project's path.",
    tag: "decisions",
  },
  {
    href: "/docs/study_guide",
    title: "Study guide",
    blurb: "Thematic, not chronological. Fourteen sections covering the technical material at study pace — read what you want, in any order.",
    tag: "study",
  },
  {
    href: "/docs/annotated_transcript",
    title: "Annotated transcript",
    blurb: "The conversation, condensed. Chat-style. Long replies squeezed to their actionable conclusion, with margin notes on the load-bearing moments.",
    tag: "transcript",
  },
];

const style = `
  :root {
    --bg: #0a0c10;
    --panel: #11141a;
    --line: #232733;
    --fg: #e7e8ea;
    --muted: #c8cbd4;
    --faint: #787d88;
    --accent: #48e5c2;
    --accent-dim: #2a8a78;
    --font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "Geist Mono", ui-monospace, "SF Mono", Monaco, "Cascadia Code", "Roboto Mono", monospace;
  }
  html, body {
    background: var(--bg); color: var(--fg);
    font: 16px/1.7 var(--font-sans);
    margin: 0; padding: 0;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 820px; margin: 0 auto; padding: 56px 24px 96px; }
  .eyebrow {
    font: 500 11px/1 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .eyebrow a { color: var(--accent); text-decoration: none; border-bottom: 1px dashed transparent; transition: border-color 0.2s; }
  .eyebrow a:hover { border-bottom-color: var(--accent); }
  .eyebrow .sep { color: var(--faint); }

  h1 { font: 600 36px/1.2 var(--font-sans); color: var(--fg); margin: 0 0 16px; letter-spacing: -0.01em; }
  .lede { color: var(--muted); font-size: 17px; line-height: 1.6; margin: 0 0 40px; max-width: 640px; }

  .doc-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }

  .doc-card {
    display: block;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 22px 24px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .doc-card:hover {
    border-color: var(--accent-dim);
    background: rgba(72, 229, 194, 0.03);
    transform: translateY(-1px);
  }
  .doc-card-head {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 16px; margin-bottom: 8px;
  }
  .doc-card-title {
    font: 600 18px/1.3 var(--font-sans);
    color: var(--fg);
  }
  .doc-card-tag {
    font: 500 10.5px/1 var(--font-mono);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: rgba(72, 229, 194, 0.06);
    border: 1px solid rgba(72, 229, 194, 0.18);
    padding: 4px 8px;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .doc-card-blurb {
    color: var(--muted);
    font-size: 14.5px;
    line-height: 1.6;
    margin: 0;
  }

  .foot {
    margin-top: 56px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
    color: var(--faint);
    font: 13px/1.6 var(--font-mono);
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .foot a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent-dim);
  }
  .foot a:hover { border-bottom-color: var(--accent); }
`;
---

<Default {...layoutProps}>
  <style is:global slot="head" set:html={style}></style>
  <div class="wrap">
    <div class="eyebrow">
      <a href="/">← TinyGPT</a>
      <span class="sep">·</span>
      <a href="/devlog">devlog</a>
      <span class="sep">·</span>
      <a href="/roadmap">roadmap</a>
      <span class="sep">·</span>
      <a href="/speedup">speedup</a>
    </div>

    <h1>Documentation</h1>
    <p class="lede">
      Six angles on the same project. Pick whichever fits — they overlap, they
      cross-reference, and any one of them is a complete view on its own. The
      markdown source lives in <code>docs/</code> in the repo and renders here.
    </p>

    <div class="doc-grid">
      {docs.map((d) => (
        <a class="doc-card" href={d.href}>
          <div class="doc-card-head">
            <span class="doc-card-title">{d.title}</span>
            <span class="doc-card-tag">{d.tag}</span>
          </div>
          <p class="doc-card-blurb">{d.blurb}</p>
        </a>
      ))}
    </div>

    <div class="foot">
      <span>TinyGPT</span>
      <span class="sep">·</span>
      <a href="https://github.com/sarthakagrawal927/tinygpt">repo ↗</a>
      <span class="sep">·</span>
      <a href="https://github.com/sarthakagrawal927/tinygpt/tree/main/docs">raw markdown ↗</a>
    </div>
  </div>
</Default>
