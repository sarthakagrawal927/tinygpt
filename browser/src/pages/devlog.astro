        --panel: #11141a;
        --panel-2: #161a22;
        --line: #232733;
        --line-strong: #2a2f3c;
        --fg: #e7e8ea;
        --muted: #c8cbd4;
        --faint: #787d88;
        --accent: #48e5c2;
        --accent-dim: #2a8a78;
