// the popover system to keep wiring up correctly.
import Default from "../layouts/Default.astro";

const layoutProps = {
  title: "TinyGPT — the speedup curve, in one chart",
  description: "WebAssembly SIMD vs hand-written WebGPU on the same GPT-2 model. The speedup is a curve, not a single number: Small 2.6×, Medium 6.8×, Large 9.3×, XL 12.1× — and growing with model size.",
  ogType: "article",
  ogTitle: "TinyGPT — 2.6× → 12.1× faster, in one chart",
  ogDescription: "WASM SIMD vs hand-written WebGPU on the same GPT-2 model. The speedup is a curve, not a single number: GPU work amortizes better as d_model grows.",
  twitterTitle: "TinyGPT — 2.6× → 12.1× faster",
  twitterDescription: "WASM SIMD vs hand-written WebGPU. Small 2.6×, Medium 6.8×, Large 9.3×, XL 12.1× — the speedup grows with model size.",
  themeColor: "#0a0c10",
  loadFonts: false,
};

const pageStyle = `
      :root {
        --bg: #0a0c10;
        --panel: #11141a;
        --line: #232733;
        --fg: #e7e8ea;
        --muted: #c8cbd4;
        --faint: #787d88;
        --accent: #48e5c2;
        --accent-dim: #2a8a78;
        --accent-glow: rgba(72, 229, 194, 0.18);
        --warn: #f5b14a;
        --font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: ui-monospace, "SF Mono", Monaco, "Cascadia Code", "Roboto Mono", monospace;
      }
      * { box-sizing: border-box; }
      html, body {
        background: var(--bg); color: var(--fg);
        font: 15px/1.55 var(--font-sans);
        margin: 0; padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 920px; margin: 0 auto; padding: 56px 28px 96px; }

      .eyebrow {
        font: 500 11px/1 var(--font-mono);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 12px;
      }
      .eyebrow a { color: var(--accent); text-decoration: none; }
      .eyebrow a:hover { text-decoration: underline; }
      h1 {
        font: 500 34px/1.15 var(--font-sans);
        margin: 0 0 16px;
        letter-spacing: -0.02em;
      }
      .lede { color: var(--muted); font-size: 16px; max-width: 720px; margin: 0 0 48px; }

      /* === The headline chart === */
      .headline {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 32px 40px 36px;
        margin: 0 0 40px;
      }
      .headline-bars {
        display: grid;
        grid-template-columns: 180px 1fr 110px;
        align-items: center;
        gap: 22px;
        margin: 18px 0;
      }
      .headline-bars .label {
        font: 500 13px/1.3 var(--font-mono);
        color: var(--muted);
        text-align: right;
      }
      .headline-bars .label small {
        display: block;
        color: var(--faint);
        font-size: 11px;
        margin-top: 4px;
      }
      .headline-bars .bar {
        height: 36px;
        border-radius: 6px;
        transition: filter 0.18s ease;
      }
      .headline-bars .bar.before {
        background: linear-gradient(90deg, rgba(245, 177, 74, 0.4), rgba(245, 177, 74, 0.65));
        width: 100%;
      }
      .headline-bars .bar.after {
        background: linear-gradient(90deg, var(--accent-dim), var(--accent));
        box-shadow: 0 0 18px var(--accent-glow);
      }
      .headline-bars .ms {
        font: 500 20px/1 var(--font-mono);
        color: var(--fg);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
      }
      .headline-bars .ms small {
        display: block;
        color: var(--faint);
        font: 500 10px/1 var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 5px;
      }

      .verdict {
        margin-top: 24px;
        padding: 14px 20px;
        border-left: 3px solid var(--accent);
        background: var(--accent-glow);
        border-radius: 0 8px 8px 0;
      }
      .verdict .big {
        font: 500 32px/1 var(--font-sans);
        color: var(--accent);
        letter-spacing: -0.02em;
        margin-right: 10px;
      }
      .verdict span { color: var(--muted); font-size: 14px; }

      .source {
        margin-top: 18px;
        font: 12.5px/1.5 var(--font-mono);
        color: var(--faint);
      }
      .source code {
        font-size: 12px;
        background: rgba(255,255,255,0.04);
        padding: 1px 5px;
        border-radius: 3px;
        color: var(--muted);
      }

      /* === The stack-up === */
      .stack {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 28px 36px 32px;
        margin: 0 0 32px;
      }
      .stack h2 {
        font: 500 19px/1.2 var(--font-sans);
        margin: 0 0 6px;
        letter-spacing: -0.01em;
      }
      .stack .sub {
        color: var(--faint);
        font: 12.5px/1.4 var(--font-mono);
        margin: 0 0 22px;
      }
      .stack-row {
        display: grid;
        grid-template-columns: 240px 1fr 90px 110px;
        align-items: center;
        gap: 18px;
        padding: 10px 0;
      }
      .stack-row + .stack-row { border-top: 1px dashed var(--line); }
      .stack-row .lbl {
        font: 500 13px/1.3 var(--font-mono);
        color: var(--muted);
      }
      .stack-row .stack-bar {
        height: 16px;
        border-radius: 3px;
      }
      .stack-row .stack-bar.measured {
        background: linear-gradient(90deg, var(--accent-dim), var(--accent));
        box-shadow: 0 0 10px var(--accent-glow);
      }
      .stack-row .stack-bar.projected {
        background: repeating-linear-gradient(
          135deg, #3a3f4a 0, #3a3f4a 6px, #4a4f5a 6px, #4a4f5a 12px
        );
        opacity: 0.7;
      }
      .stack-row .val {
        font: 500 14px/1 var(--font-mono);
        color: var(--fg);
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .stack-row .tag {
        font: 500 10px/1 var(--font-mono);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--faint);
      }
      .stack-row .tag.m { color: var(--accent); }

      .foot {
        margin-top: 40px;
        font-size: 14px;
        color: var(--muted);
      }
      .foot a { color: var(--accent); text-decoration: none; border-bottom: 1px dashed var(--accent-dim); }
      .foot a:hover { border-bottom-color: var(--accent); }
    `;

const pageBody = `
    <div class="wrap">
      <div class="eyebrow"><a href="/">← TinyGPT</a> · <a href="/roadmap">roadmap</a> · <a href="/devlog">devlog</a> · <a href="/docs">docs</a></div>
      <h1>The speedup, measured — and why it's a curve</h1>
      <p class="lede">
        Same model, same seed, same data, same Apple M-series laptop. Two backends.
        The speedup grows with <code>d_model</code> because GPU work amortizes better
        as matmul shapes grow. Run it yourself: <code>tests/test_webgpu_train.mjs</code>.
      </p>

      <!-- HEADLINE — small multiples, one bar pair per preset -->
      <div class="headline">
        <div class="headline-bars">
          <div class="label">Small · d=96<small>WASM SIMD (mt)</small></div>
          <div class="bar before" style="width: 100%"></div>
          <div class="ms">2.6×<small>WebGPU faster</small></div>
        </div>
        <div class="headline-bars">
          <div class="label">Medium · d=128<small>WASM SIMD (mt)</small></div>
          <div class="bar before" style="width: 100%"></div>
          <div class="ms">6.8×<small>WebGPU faster</small></div>
        </div>
        <div class="headline-bars">
          <div class="label">Large · d=192<small>WASM SIMD (mt)</small></div>
          <div class="bar before" style="width: 100%"></div>
          <div class="ms">9.3×<small>WebGPU faster</small></div>
        </div>
        <div class="headline-bars">
          <div class="label">XL · d=256<small>WASM SIMD (mt)</small></div>
          <div class="bar before" style="width: 100%"></div>
          <div class="ms">12.1×<small>WebGPU faster</small></div>
        </div>
        <div class="verdict">
          <span class="big">12.1×</span>
          <span>at XL — and growing with model size. 1.1–2.5% loss drift across the curve (pure float-reorder noise from different GPU accumulation order).</span>
        </div>
        <div class="source">
          Measured via <code>tests/test_webgpu_train.mjs</code>. WebGPU run uses
          the full stack: <code>matmul_blocked</code> + vec4 loads,
          subgroup-cooperative layernorm + cross-entropy, and Flash Attention 2
          forward + backward. Mega and Behemoth presets are omitted —
          a Memory64 ABI bug at the JS↔WASM bridge (task #66) currently
          blocks an honest in-browser end-to-end measurement.
        </div>
      </div>

      <!-- WHY IT'S A CURVE -->
      <div class="stack">
        <h2>Why the speedup is a curve, not a single number</h2>
        <p class="sub">Every training step costs <code>fixed_overhead + math(model_size)</code>. The overhead is roughly the same on both backends; only the math piece scales. So small models are bottlenecked on per-step overhead and look "only" 2.6× faster on the GPU; big models are bottlenecked on the math itself, and the GPU's arithmetic throughput dominates.</p>

        <div class="stack-row">
          <div class="lbl">scalar WASM baseline</div>
          <div class="stack-bar measured" style="width: 1.4%"></div>
          <div class="val">1.0×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WASM SIMD</div>
          <div class="stack-bar measured" style="width: 2.3%"></div>
          <div class="val">1.6×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ multi-thread (4 workers)</div>
          <div class="stack-bar measured" style="width: 4.6%"></div>
          <div class="val">3.2×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU full stack — Small (d=96)</div>
          <div class="stack-bar measured" style="width: 13%"></div>
          <div class="val">~8.3×</div>
          <div class="tag m">2.6× over WASM-SIMD-mt</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU full stack — Medium (d=128)</div>
          <div class="stack-bar measured" style="width: 34%"></div>
          <div class="val">~22×</div>
          <div class="tag m">6.8× over WASM-SIMD-mt</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU full stack — Large (d=192)</div>
          <div class="stack-bar measured" style="width: 47%"></div>
          <div class="val">~30×</div>
          <div class="tag m">9.3× over WASM-SIMD-mt</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU full stack — XL (d=256)</div>
          <div class="stack-bar measured" style="width: 60%"></div>
          <div class="val">~39×</div>
          <div class="tag m">12.1× over WASM-SIMD-mt · top measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">Mega / Behemoth (projected)</div>
          <div class="stack-bar projected" style="width: 80%"></div>
          <div class="val">≥ 15×</div>
          <div class="tag">projected · blocked by Memory64 ABI bug</div>
        </div>

        <p class="sub" style="margin-top: 16px;">
          Each "WebGPU full stack" row is the same code: blocked4 matmul + vec4
          loads + subgroup-cooperative reductions + Flash Attention 2 forward and
          backward. These aren't independent additive levers any more — they're
          the shipped default WebGPU path.
        </p>
      </div>

      <div class="foot">
        Full benchmark log + the three things that <em>didn't</em> work →
        <a href="/devlog">/devlog</a> · <a href="/roadmap">/roadmap</a>
      </div>
    </div>
  `;
---

<Default {...layoutProps}>
  <style is:global slot="head" set:html={pageStyle}></style>
  <Fragment set:html={pageBody} />

</Default>
