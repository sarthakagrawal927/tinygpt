// the popover system to keep wiring up correctly.
import Default from "../layouts/Default.astro";

const layoutProps = {
  title: "TinyGPT — the speedup, in one chart",
  description: "WebAssembly SIMD vs hand-written WebGPU on the same GPT-2 model — 6.8 s/step down to 0.7 s/step, 9.7× end-to-end, 1.1% loss drift.",
  ogType: "article",
  ogTitle: "TinyGPT — 9.7× faster in one chart",
  ogDescription: "WASM SIMD: 6.8 s/step. WebGPU with the blocked-4×4 matmul kernel: 0.7 s/step. Same model, same seed, 1.1% loss drift — pure float-reorder noise.",
  twitterTitle: "TinyGPT — 9.7× faster, in one chart",
  twitterDescription: "WASM SIMD vs hand-written WebGPU on the same GPT-2 model. 9.7× end-to-end, 1.1% loss drift.",
  themeColor: "#0a0c10",
  loadFonts: false,
};

const pageStyle = `
      :root {
        --bg: #0a0c10;
        --panel: #11141a;
        --line: #232733;
        --fg: #e7e8ea;
        --muted: #c8cbd4;
        --faint: #787d88;
        --accent: #48e5c2;
        --accent-dim: #2a8a78;
        --accent-glow: rgba(72, 229, 194, 0.18);
        --warn: #f5b14a;
        --font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: ui-monospace, "SF Mono", Monaco, "Cascadia Code", "Roboto Mono", monospace;
      }
      * { box-sizing: border-box; }
      html, body {
        background: var(--bg); color: var(--fg);
        font: 15px/1.55 var(--font-sans);
        margin: 0; padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 920px; margin: 0 auto; padding: 56px 28px 96px; }

      .eyebrow {
        font: 500 11px/1 var(--font-mono);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 12px;
      }
      .eyebrow a { color: var(--accent); text-decoration: none; }
      .eyebrow a:hover { text-decoration: underline; }
      h1 {
        font: 500 34px/1.15 var(--font-sans);
        margin: 0 0 16px;
        letter-spacing: -0.02em;
      }
      .lede { color: var(--muted); font-size: 16px; max-width: 720px; margin: 0 0 48px; }

      /* === The headline chart === */
      .headline {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 32px 40px 36px;
        margin: 0 0 40px;
      }
      .headline-bars {
        display: grid;
        grid-template-columns: 180px 1fr 110px;
        align-items: center;
        gap: 22px;
        margin: 18px 0;
      }
      .headline-bars .label {
        font: 500 13px/1.3 var(--font-mono);
        color: var(--muted);
        text-align: right;
      }
      .headline-bars .label small {
        display: block;
        color: var(--faint);
        font-size: 11px;
        margin-top: 4px;
      }
      .headline-bars .bar {
        height: 36px;
        border-radius: 6px;
        transition: filter 0.18s ease;
      }
      .headline-bars .bar.before {
        background: linear-gradient(90deg, rgba(245, 177, 74, 0.4), rgba(245, 177, 74, 0.65));
        width: 100%;
      }
      .headline-bars .bar.after {
        background: linear-gradient(90deg, var(--accent-dim), var(--accent));
        box-shadow: 0 0 18px var(--accent-glow);
      }
      .headline-bars .ms {
        font: 500 20px/1 var(--font-mono);
        color: var(--fg);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
      }
      .headline-bars .ms small {
        display: block;
        color: var(--faint);
        font: 500 10px/1 var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 5px;
      }

      .verdict {
        margin-top: 24px;
        padding: 14px 20px;
        border-left: 3px solid var(--accent);
        background: var(--accent-glow);
        border-radius: 0 8px 8px 0;
      }
      .verdict .big {
        font: 500 32px/1 var(--font-sans);
        color: var(--accent);
        letter-spacing: -0.02em;
        margin-right: 10px;
      }
      .verdict span { color: var(--muted); font-size: 14px; }

      .source {
        margin-top: 18px;
        font: 12.5px/1.5 var(--font-mono);
        color: var(--faint);
      }
      .source code {
        font-size: 12px;
        background: rgba(255,255,255,0.04);
        padding: 1px 5px;
        border-radius: 3px;
        color: var(--muted);
      }

      /* === The stack-up === */
      .stack {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 28px 36px 32px;
        margin: 0 0 32px;
      }
      .stack h2 {
        font: 500 19px/1.2 var(--font-sans);
        margin: 0 0 6px;
        letter-spacing: -0.01em;
      }
      .stack .sub {
        color: var(--faint);
        font: 12.5px/1.4 var(--font-mono);
        margin: 0 0 22px;
      }
      .stack-row {
        display: grid;
        grid-template-columns: 240px 1fr 90px 110px;
        align-items: center;
        gap: 18px;
        padding: 10px 0;
      }
      .stack-row + .stack-row { border-top: 1px dashed var(--line); }
      .stack-row .lbl {
        font: 500 13px/1.3 var(--font-mono);
        color: var(--muted);
      }
      .stack-row .stack-bar {
        height: 16px;
        border-radius: 3px;
      }
      .stack-row .stack-bar.measured {
        background: linear-gradient(90deg, var(--accent-dim), var(--accent));
        box-shadow: 0 0 10px var(--accent-glow);
      }
      .stack-row .stack-bar.projected {
        background: repeating-linear-gradient(
          135deg, #3a3f4a 0, #3a3f4a 6px, #4a4f5a 6px, #4a4f5a 12px
        );
        opacity: 0.7;
      }
      .stack-row .val {
        font: 500 14px/1 var(--font-mono);
        color: var(--fg);
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .stack-row .tag {
        font: 500 10px/1 var(--font-mono);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--faint);
      }
      .stack-row .tag.m { color: var(--accent); }

      .foot {
        margin-top: 40px;
        font-size: 14px;
        color: var(--muted);
      }
      .foot a { color: var(--accent); text-decoration: none; border-bottom: 1px dashed var(--accent-dim); }
      .foot a:hover { border-bottom-color: var(--accent); }
    `;

const pageBody = `
    <div class="wrap">
      <div class="eyebrow"><a href="/">← TinyGPT</a> · <a href="/roadmap">roadmap</a> · <a href="/devlog">devlog</a></div>
      <h1>The speedup, measured</h1>
      <p class="lede">
        Same model, same seed, same data, same Apple M-series laptop. Just two backends.
        Run it yourself: <code>tests/test_webgpu_train.mjs</code> at the repo root.
      </p>

      <!-- HEADLINE -->
      <div class="headline">
        <div class="headline-bars">
          <div class="label">WASM SIMD<small>multi-threaded baseline</small></div>
          <div class="bar before" style="width: 100%"></div>
          <div class="ms">6.8 s<small>per step</small></div>
        </div>
        <div class="headline-bars">
          <div class="label">WebGPU + this work<small>blocked4 + subgroups + FA2 fwd&nbsp;+&nbsp;bwd + Memory64</small></div>
          <div class="bar after" style="width: 10.3%"></div>
          <div class="ms">0.7 s<small>per step</small></div>
        </div>
        <div class="verdict">
          <span class="big">9.7×</span>
          <span>faster end-to-end. 50 training steps · Small preset · 1.1% loss drift (pure float-reorder noise).</span>
        </div>
        <div class="source">
          Measured via <code>tests/test_webgpu_train.mjs</code>. Same seed, identical
          tokenization, identical AdamW state. WebGPU run uses the
          <code>matmul_blocked</code> kernel (this work), subgroup-cooperative layernorm
          + cross-entropy, and the fused softmax+value attention forward.
        </div>
      </div>

      <!-- STACK-UP -->
      <div class="stack">
        <h2>Where the 9.7× actually came from</h2>
        <p class="sub">Each row is the cumulative speedup over a single-threaded scalar WASM baseline. Solid = measured; striped = projected.</p>

        <div class="stack-row">
          <div class="lbl">scalar WASM baseline</div>
          <div class="stack-bar measured" style="width: 1.4%"></div>
          <div class="val">1.0×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WASM SIMD</div>
          <div class="stack-bar measured" style="width: 2.3%"></div>
          <div class="val">1.6×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ multi-thread (4 workers)</div>
          <div class="stack-bar measured" style="width: 4.6%"></div>
          <div class="val">3.2×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU naive</div>
          <div class="stack-bar measured" style="width: 10%"></div>
          <div class="val">~7×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU blocked matmul</div>
          <div class="stack-bar measured" style="width: 13.9%"></div>
          <div class="val">9.7×</div>
          <div class="tag m">measured</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ on big-matmul presets (Mega+)</div>
          <div class="stack-bar measured" style="width: 43%"></div>
          <div class="val">~30×</div>
          <div class="tag m">measured (kernel)</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ WebGPU subgroups</div>
          <div class="stack-bar projected" style="width: 52%"></div>
          <div class="val">~36×</div>
          <div class="tag">projected</div>
        </div>
        <div class="stack-row">
          <div class="lbl">+ Flash Attention 2 (fwd + bwd)</div>
          <div class="stack-bar measured" style="width: 80%"></div>
          <div class="val">~50×</div>
          <div class="tag m">shipped</div>
        </div>
      </div>

      <div class="foot">
        Full benchmark log + the three things that <em>didn't</em> work →
        <a href="/devlog">/devlog</a> · <a href="/roadmap">/roadmap</a>
      </div>
    </div>
  `;
---

<Default {...layoutProps}>
  <style is:global slot="head" set:html={pageStyle}></style>
  <Fragment set:html={pageBody} />

</Default>
