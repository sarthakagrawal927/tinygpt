    "astro": "^5.0.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "posthog-js": "^1.376.2"
  }
}
