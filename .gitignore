# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Node / browser build
node_modules/
dist/
.vite/
.wrangler/

# Local environment files (PostHog keys, etc — never committed)
browser/.env
browser/.env.local

# The compiled WASM modules (browser/public/tinygpt{,64}.{js,wasm}) USED to
# be gitignored as build artifacts, but Cloudflare Pages does a fresh
# `git clone` + `npm run build` and never re-builds the WASM — so leaving
# them ignored 404s the production playground at runtime. They're now
# committed alongside the C++ source changes. See docs/deploy.md.
#
# Re-rebuilding locally: bash wasm/build_wasm.sh && bash wasm/build_wasm64.sh
# (then commit the diff as part of the same PR as the .cpp change.)

# Build scratch directories
wasm/build/
dist/tinygpt.js
dist/tinygpt.simd.js
# .wasm.map files are sourcemaps and stay ignored.
*.wasm.map

# Checkpoints & weights (large binary; keep checkpoints/README.md)
checkpoints/*
!checkpoints/README.md
*.f32
*.bin
*.pt
*.ckpt

# Datasets (keep examples/ and READMEs; ignore bulk corpora)
data/raw/
data/*.txt
data/*.jsonl
!data/examples/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
.symphony/

# Astro generated cache
browser/.astro/
