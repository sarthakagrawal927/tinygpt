# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Node / browser build
node_modules/
dist/
.vite/
.wrangler/

# Local environment files (PostHog keys, etc — never committed)
browser/.env
browser/.env.local

# The compiled WASM modules (browser/public/tinygpt{,64}.{js,wasm}) USED to
# be gitignored as build artifacts, but Cloudflare Pages does a fresh
# `git clone` + `npm run build` and never re-builds the WASM — so leaving
# them ignored 404s the production playground at runtime. They're now
# committed alongside the C++ source changes. See docs/deploy.md.
#
# Re-rebuilding locally: bash wasm/build_wasm.sh && bash wasm/build_wasm64.sh
# (then commit the diff as part of the same PR as the .cpp change.)

# Build scratch directories
wasm/build/
dist/tinygpt.js
dist/tinygpt.simd.js
# .wasm.map files are sourcemaps and stay ignored.
*.wasm.map

# Checkpoints & weights (large binary; keep checkpoints/README.md)
checkpoints/*
!checkpoints/README.md
*.f32
*.bin
*.pt
*.ckpt
# Gallery model files MUST be committed — they're the shipped artifact
# and renamed to .bin so Cloudflare Pages caches them at the edge.
!browser/public/gallery/*.bin

# Datasets (keep examples/ and READMEs; ignore bulk corpora)
data/raw/
data/*.txt
data/*.jsonl
!data/examples/

# Reference checkpoints (e.g. huge Shakespeare model, ~110MB) are too big
# for git but useful to keep locally. The bundled browser demo
# (browser/public/demo.tinygpt) is committed; everything else stays out.
data/checkpoints/*.tinygpt

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
.symphony/

# Astro generated cache
browser/.astro/

# Pre-build copy of docs/*.md into Astro's src tree — generated by
# browser/scripts/copy_docs.mjs at every `npm run dev` / `npm run build`,
# the canonical source lives in /docs.
browser/src/content/docs/

# native-mac build artifacts
native-mac/.xcode-build/
native-mac/.build/
native-mac/Package.resolved

# uv venv for Python ANE conversion (local-only — managed by uv)
python_ref/.venv/
python_ref/.python-version
